VITE_API_BASE=http://localhost:8000/api

# Must match DEMO_RESET_SECRET in backend/.env
VITE_DEMO_RESET_SECRET=change_me_before_demo

# Camera 1: Server Room
VITE_CAM_01_SOURCE=stream
VITE_CAM_01_STREAM_URL=
VITE_CAM_01_LOCATION=server_room
VITE_CAM_01_PROCESSING_INTERVAL_MS=500
VITE_CAM_01_PROCESSING_ENABLED=true

# Camera 2: Lobby
VITE_CAM_02_SOURCE=stream
VITE_CAM_02_STREAM_URL=
VITE_CAM_02_LOCATION=lobby
VITE_CAM_02_PROCESSING_INTERVAL_MS=500
VITE_CAM_02_PROCESSING_ENABLED=true

# Camera 3: Gathering Area
VITE_CAM_03_SOURCE=stream
VITE_CAM_03_STREAM_URL=
VITE_CAM_03_LOCATION=gathering_area
VITE_CAM_03_PROCESSING_INTERVAL_MS=500
VITE_CAM_03_PROCESSING_ENABLED=true

# Demo-only preview cameras.
# Demo videos are NOT committed to Git. To preview one locally, drop a file into
# frontend/public/videos/ and set the matching VITE_CAM_xx_VIDEO_URL in
# frontend/.env.local (which is git-ignored). Left blank, these cameras stay as
# inert placeholders and do not process frames.
VITE_CAM_04_SOURCE=placeholder
VITE_CAM_04_LOCATION=parking_area
VITE_CAM_04_VIDEO_URL=
VITE_CAM_04_PROCESSING_ENABLED=false

VITE_CAM_05_SOURCE=placeholder
VITE_CAM_05_LOCATION=multi_purpose_room
VITE_CAM_05_VIDEO_URL=
VITE_CAM_05_PROCESSING_ENABLED=false

VITE_CAM_06_SOURCE=placeholder
VITE_CAM_06_LOCATION=store_room
VITE_CAM_06_VIDEO_URL=
VITE_CAM_06_PROCESSING_ENABLED=false
