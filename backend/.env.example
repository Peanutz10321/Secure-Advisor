# =========================================================
# Backend Environment Template
# Copy this file to .env and fill in local values.
# Do not commit the real .env file.
# =========================================================

# OpenAI advisory engine
# Required if AI advisory generation is enabled.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Secret token required in the X-Demo-Secret header to call POST /api/demo/reset.
# Set to any long random string. Leave empty to disable the endpoint entirely.
DEMO_RESET_SECRET=change_me_before_demo

# Frontend origins allowed by CORS.
# Add localhost ports and local network IPs used during demo.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://YOUR_LAPTOP_IP:5173,http://YOUR_LAPTOP_IP:5174,http://YOUR_LAPTOP_IP:5175


# =========================================================
# Fight Detection Configuration
# =========================================================

# Fight detection mode:
# off    = disable fight incident detection
# local  = use backend/models/fight_classifier.pt
# remote = use external AI service
FIGHT_DETECTION_MODE=off

# Local model, used only when FIGHT_DETECTION_MODE=local
LOCAL_FIGHT_MODEL_PATH=models/fight_classifier.pt

# Remote model, used only when FIGHT_DETECTION_MODE=remote
# Example: http://192.168.1.23:9000/predict-fight-clip
FIGHT_CLASSIFIER_URL=http://YOUR_AI_SERVICE_IP:9000/predict-fight-clip

# Number of recent CCTV frames sent to the fight AI service per clip
FIGHT_CLIP_FRAME_COUNT=16

# Timeout when calling the remote fight AI service (seconds)
FIGHT_REMOTE_TIMEOUT_SECONDS=5

# Minimum time between remote fight AI calls per camera (seconds)
FIGHT_REMOTE_DECISION_INTERVAL_SECONDS=2

# How many consecutive frames without 2+ people before the fight buffer resets
FIGHT_PERSON_MISSING_GRACE_FRAMES=3